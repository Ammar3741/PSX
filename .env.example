# ============================================================
# PSX Stock Monitor — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control!
# ============================================================

# ── Email alert recipient ────────────────────────────────────
TARGET_EMAIL=ammarilyas343@gmail.com

# ── Resend API (https://resend.com) ─────────────────────────
# Your Resend API key — REQUIRED for email alerts to work
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Flask / database ─────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
# For Railway Postgres add your connection string here:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Leave blank to use SQLite locally:
DATABASE_URL=sqlite:///alerts.db

# ── Alert logic ──────────────────────────────────────────────
# Minimum price surge % to trigger an alert (default 4.0)
ALERT_THRESHOLD=4.0

# Rolling monitoring window in seconds (default 1200 = 20 min)
MONITOR_WINDOW=1200

# Minimum traded value in Rupees to qualify for an alert (default 20000000 = 2 Crore)
MIN_VALUE_THRESHOLD=20000000

# ── Daily reset schedule (PKT = UTC+5) ───────────────────────
# 'alerted' flags are cleared once per day after market close.
# Default: 15:30 PKT (PSX regular session close)
MARKET_CLOSE_HOUR=15
MARKET_CLOSE_MINUTE=30